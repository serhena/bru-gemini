{
  "entities": {
    "booking": {
      "title": "Booking",
      "description": "A guitar restringing booking request.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Customer name" },
        "email": { "type": "string", "format": "email", "description": "Customer email" },
        "stringType": { "type": "string", "enum": ["Polyester", "Synthetic Gut", "Multifilament", "Hybrid"], "description": "Type of string" },
        "tension": { "type": "number", "description": "String tension in lbs" },
        "message": { "type": "string", "description": "Additional details" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed"], "description": "Booking status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Time of booking request" }
      },
      "required": ["name", "email", "stringType", "tension", "createdAt"]
    }
  },
  "firestore": {
    "/bookings/{bookingId}": {
      "schema": "booking",
      "description": "Collection of booking requests"
    }
  }
}
